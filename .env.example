# Groq API key. Required. Get one at https://console.groq.com
GROQ_API_KEY=

# Disable auto-paste. When set to a truthy value (1, true, yes, on) scribe
# only copies to the clipboard and you paste manually with Ctrl+Shift+V.
# Default: 0 (auto-paste enabled).
#
# SCRIBE_NO_AUTO_PASTE=0

# Auto-paste mechanism. Options:
#   shortcut — Ctrl+Shift+V via ydotool. Instant. Works in terminals (Claude
#              Code, gnome-terminal) and Electron apps (Discord). Won't fire
#              in native GTK/GNOME apps like gnome-text-editor.
#   ctrl_v   — Ctrl+V via ydotool. Instant. Works in GTK/GNOME apps and most
#              browsers. Do NOT use with a terminal focused — inserts literal
#              ^V instead of pasting.
#   type     — Types each character via ydotool. ~10ms/char (slow for long
#              prompts) but works in every focused input.
# Default: shortcut
#
# SCRIBE_PASTE_MODE=shortcut

# Push-to-talk key. Any evdev key name. List them with:
#   python -c "from evdev import ecodes; print(sorted(n for n in dir(ecodes) if n.startswith('KEY_')))"
# Default: KEY_RIGHTCTRL
#
# SCRIBE_HOTKEY=KEY_RIGHTCTRL

# Minimum hold duration (seconds). Shorter holds are dropped as accidental taps
# and never sent to Groq.
# Default: 0.3
#
# SCRIBE_MIN_DURATION_S=0.3

# Maximum hold duration (seconds). The recording auto-stops at this point.
# Default: 60.0
#
# SCRIBE_MAX_DURATION_S=60.0

# Groq Whisper model. Alternative: whisper-large-v3 (slower, slightly more
# accurate, multilingual).
# Default: whisper-large-v3-turbo
#
# SCRIBE_MODEL=whisper-large-v3-turbo

# Transcription prompt. Comma-separated vocabulary biases Whisper toward
# domain-specific proper nouns and identifiers (project names, library names,
# coworker names, etc.) that the base model otherwise mis-hears. Limit ~224
# tokens.
# Default: empty (no prompt).
#
# SCRIBE_PROMPT=Anthropic, OAuth, GitHub, TypeScript
