#!/usr/bin/env bash
# scribe — control the Scribe dictation daemon.
#
# Installed by install.sh; __SCRIBE_DIR__ is replaced at install time with the
# absolute path of the repo so this script can find .env.

set -euo pipefail

SCRIBE_DIR="__SCRIBE_DIR__"
# .env lives under XDG_CONFIG_HOME so it survives uninstall/reinstall.
ENV_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/scribe/.env"
SERVICE="scribe.service"

if [[ -t 1 ]]; then
  R=$'\033[31m'; G=$'\033[32m'; Y=$'\033[33m'; C=$'\033[36m'; M=$'\033[35m'
  B=$'\033[1m'; D=$'\033[2m'; N=$'\033[0m'
else
  R=; G=; Y=; C=; M=; B=; D=; N=
fi

print_logo() {
  [[ -t 1 ]] || return 0
  printf '%s' "$M"
  cat <<'BANNER'

   ███████╗ ██████╗██████╗ ██╗██████╗ ███████╗
   ██╔════╝██╔════╝██╔══██╗██║██╔══██╗██╔════╝
   ███████╗██║     ██████╔╝██║██████╔╝█████╗
   ╚════██║██║     ██╔══██╗██║██╔══██╗██╔══╝
   ███████║╚██████╗██║  ██║██║██████╔╝███████╗
   ╚══════╝ ╚═════╝╚═╝  ╚═╝╚═╝╚═════╝ ╚══════╝
BANNER
  printf '%s' "$N"
  printf "   %sPush-to-talk dictation for Linux, powered by Groq Whisper%s\n\n" "$D" "$N"
}

# Arrow-key Yes/No selector. Echoes 0 (Yes) or 1 (No).
# Falls back to a Y/n prompt if there's no tty.
select_yes_no() {
  local prompt=$1
  local selected=${2:-0}
  local options=("Yes" "No")
  local count=2
  local key rest old_stty i ans

  if [[ ! -e /dev/tty ]]; then
    local hint="Y/n"
    (( selected == 1 )) && hint="y/N"
    printf "  %s%s%s %s[%s]%s: " "$C" "$prompt" "$N" "$D" "$hint" "$N" >&2
    read -r ans
    if [[ -z $ans ]]; then
      echo "$selected"
    elif [[ $ans =~ ^[Yy] ]]; then
      echo 0
    else
      echo 1
    fi
    return
  fi

  old_stty=$(stty -g </dev/tty)
  stty -icanon -echo min 1 time 0 </dev/tty
  printf '\033[?25l' >/dev/tty
  trap '
    stty "$old_stty" </dev/tty 2>/dev/null
    printf "\033[?25h" >/dev/tty 2>/dev/null
    exit 130
  ' INT

  draw_yn() {
    {
      printf "  %s%s%s\n" "$C" "$prompt" "$N"
      printf "    "
      for i in "${!options[@]}"; do
        if (( i == selected )); then
          printf "%s❯%s %s%s%s    " "$M" "$N" "$B$C" "${options[i]}" "$N"
        else
          printf "  %s%s%s    " "$D" "${options[i]}" "$N"
        fi
      done
      printf "\n"
      printf "  %s←→ navigate, enter to select%s\n" "$D" "$N"
    } >/dev/tty
  }

  draw_yn
  while true; do
    IFS= read -rsn1 key </dev/tty
    if [[ $key == $'\x1b' ]]; then
      IFS= read -rsn2 -t 0.05 rest </dev/tty || rest=""
      case $rest in
        '[C') (( selected = (selected + 1) % count ))
              printf "\033[3A" >/dev/tty; draw_yn ;;
        '[D') (( selected = (selected - 1 + count) % count ))
              printf "\033[3A" >/dev/tty; draw_yn ;;
      esac
    elif [[ -z $key ]]; then
      {
        printf "\033[3A"
        printf '\033[J'
        printf "  %s%s%s %s%s%s\n" "$C" "$prompt" "$N" "$B" "${options[selected]}" "$N"
      } >/dev/tty
      stty "$old_stty" </dev/tty
      printf "\033[?25h" >/dev/tty
      trap - INT
      echo "$selected"
      return
    fi
  done
}

# Print a one-line summary of the current service state. Best-effort; if
# `systemctl status` parsing fails (locale, systemd version), we degrade
# gracefully to just the state word.
status_line() {
  local state pid uptime
  state=$(systemctl --user is-active "$SERVICE" 2>/dev/null || true)
  pid=$(systemctl --user show -p MainPID --value "$SERVICE" 2>/dev/null || true)
  uptime=$(systemctl --user status "$SERVICE" --no-pager 2>/dev/null \
           | sed -nE 's/.*Active: active \([^)]+\) since [^;]+; (.+) ago.*/\1/p' \
           | head -1 || true)

  case "$state" in
    active)
      if [[ -n "$uptime" && -n "$pid" && "$pid" != "0" ]]; then
        printf "  %s●%s Scribe is %s%srunning%s (pid %s, up %s)\n" \
          "$G" "$N" "$G" "$B" "$N" "$pid" "$uptime"
      elif [[ -n "$pid" && "$pid" != "0" ]]; then
        printf "  %s●%s Scribe is %s%srunning%s (pid %s)\n" \
          "$G" "$N" "$G" "$B" "$N" "$pid"
      else
        printf "  %s●%s Scribe is %s%srunning%s\n" "$G" "$N" "$G" "$B" "$N"
      fi
      ;;
    inactive)
      printf "  %s○%s Scribe is %sstopped%s\n" "$D" "$N" "$D" "$N"
      ;;
    failed)
      printf "  %s✗%s Scribe %scrashed%s — see logs: journalctl --user -u scribe -n 50\n" \
        "$R" "$N" "$R$B" "$N"
      ;;
    activating)
      printf "  %s●%s Scribe is %sstarting…%s\n" "$Y" "$N" "$Y" "$N"
      ;;
    deactivating)
      printf "  %s●%s Scribe is %sstopping…%s\n" "$Y" "$N" "$Y" "$N"
      ;;
    "")
      printf "  %s✗%s Scribe isn't set up yet — run install.sh to get started.\n" \
        "$R" "$N"
      ;;
    *)
      printf "  %s●%s Scribe: %s\n" "$Y" "$N" "$state"
      ;;
  esac
}

cmd_start() {
  local state
  state=$(systemctl --user is-active "$SERVICE" 2>/dev/null || true)
  if [[ "$state" == "active" ]]; then
    printf "  %s●%s Scribe is already running.\n" "$Y" "$N"
    status_line
    return 0
  fi
  printf "  %s→ starting Scribe…%s\n" "$D" "$N"
  if ! systemctl --user start "$SERVICE"; then
    printf "  %s✗%s Couldn't start Scribe — see logs: journalctl --user -u scribe -n 50\n" "$R" "$N"
    exit 1
  fi
  status_line
}

cmd_stop() {
  local state
  state=$(systemctl --user is-active "$SERVICE" 2>/dev/null || true)
  if [[ "$state" != "active" && "$state" != "activating" ]]; then
    printf "  %s○%s Scribe is already stopped.\n" "$D" "$N"
    return 0
  fi
  printf "  %s→ stopping Scribe…%s\n" "$D" "$N"
  if ! systemctl --user stop "$SERVICE"; then
    printf "  %s✗%s Couldn't stop Scribe.\n" "$R" "$N"
    exit 1
  fi
  printf "  %s○%s Scribe %sstopped%s.\n" "$D" "$N" "$D" "$N"
}

cmd_restart() {
  printf "  %s→ restarting Scribe…%s\n" "$D" "$N"
  if ! systemctl --user restart "$SERVICE"; then
    printf "  %s✗%s Couldn't restart Scribe — see logs: journalctl --user -u scribe -n 50\n" "$R" "$N"
    exit 1
  fi
  status_line
}

cmd_test() {
  local py="$SCRIBE_DIR/.venv/bin/python"
  local helper="$SCRIBE_DIR/scribe_test.py"
  if [[ ! -x "$py" ]]; then
    printf "  %s✗%s Scribe isn't fully installed yet — run install.sh first.\n" \
      "$R" "$N" >&2
    exit 1
  fi
  if [[ ! -f "$helper" ]]; then
    printf "  %s✗%s Can't find the test script at %s — the repo may be incomplete.\n" \
      "$R" "$N" "$helper" >&2
    exit 1
  fi
  exec "$py" "$helper"
}

# Read a key from .env, ignoring commented lines. Echoes the value, or empty.
env_get() {
  local key=$1
  [[ -f "$ENV_FILE" ]] || return 0
  grep -E "^[[:space:]]*$key=" "$ENV_FILE" 2>/dev/null \
    | tail -1 | cut -d= -f2- || true
}

cmd_status() {
  status_line

  local enabled enabled_color enabled_text
  enabled=$(systemctl --user is-enabled "$SERVICE" 2>/dev/null || true)
  case "$enabled" in
    enabled)         enabled_color="$G"; enabled_text="enabled" ;;
    disabled|static) enabled_color="$Y"; enabled_text="$enabled" ;;
    "")              enabled_color="$D"; enabled_text="unknown" ;;
    *)               enabled_color="$D"; enabled_text="$enabled" ;;
  esac
  printf "  %sAutostart:%s   %s%s%s\n" "$D" "$N" "$enabled_color" "$enabled_text" "$N"

  local hotkey paste
  hotkey=$(env_get SCRIBE_HOTKEY)
  if [[ -z "$hotkey" ]]; then
    printf "  %sHotkey:%s      KEY_RIGHTCTRL %s(default)%s\n" "$D" "$N" "$D" "$N"
  else
    printf "  %sHotkey:%s      %s\n" "$D" "$N" "$hotkey"
  fi

  paste=$(env_get SCRIBE_PASTE_MODE)
  if [[ -z "$paste" ]]; then
    printf "  %sPaste mode:%s  shortcut %s(default)%s\n" "$D" "$N" "$D" "$N"
  else
    printf "  %sPaste mode:%s  %s\n" "$D" "$N" "$paste"
  fi

  echo
  printf "  %sRecent logs:%s\n" "$D" "$N"
  local logs line
  logs=$(journalctl --user -u "$SERVICE" --no-pager -n 6 -o cat 2>/dev/null || true)
  if [[ -n "$logs" ]]; then
    while IFS= read -r line; do
      printf "    %s│%s %s\n" "$D" "$N" "$line"
    done <<< "$logs"
  else
    printf "    %s(no logs yet)%s\n" "$D" "$N"
  fi
}

usage() {
  print_logo
  printf "  %sUsage:%s %sscribe%s <command> [args]\n\n" "$B" "$N" "$C$B" "$N"
  printf "  %sCommands:%s\n" "$B" "$N"
  printf "      %sstart%s              Start Scribe.\n" "$C$B" "$N"
  printf "      %sstop%s               Stop Scribe.\n" "$C$B" "$N"
  printf "      %srestart%s            Restart Scribe.\n" "$C$B" "$N"
  printf "      %sstatus%s             Show whether Scribe is running.\n" "$C$B" "$N"
  printf "      %stest%s               Record a clip and show the transcript.\n" "$C$B" "$N"
  printf "      %slist%s               Show your custom vocabulary.\n" "$C$B" "$N"
  printf "      %sadd%s <word>…        Add words to your custom vocabulary.\n" "$C$B" "$N"
  printf "      %sremove%s <word>…     Remove words from your custom vocabulary.\n" "$C$B" "$N"
  printf "      %supdate%s             Update Scribe to the latest version.\n" "$C$B" "$N"
  printf "      %suninstall%s [-y]     Uninstall Scribe (asks before removing anything).\n\n" "$C$B" "$N"
  printf "  %s.env:%s %s\n\n" "$D" "$N" "$ENV_FILE"
}

# Locate SCRIBE_PROMPT and echo "<line_idx>\t<current_value>". Last match wins
# so a real setting below a commented placeholder takes precedence. Either or
# both fields may be empty.
_vocab_read() {
  local line_idx="" current=""
  if [[ -f "$ENV_FILE" ]]; then
    line_idx=$(grep -nE '^[[:space:]]*#?[[:space:]]*SCRIBE_PROMPT=' "$ENV_FILE" \
               | tail -1 | cut -d: -f1 || true)
    if [[ -n "$line_idx" ]]; then
      current=$(sed -n "${line_idx}p" "$ENV_FILE" \
                | sed -E 's/^[[:space:]]*#?[[:space:]]*SCRIBE_PROMPT=//')
      current="${current%\"}"; current="${current#\"}"
    fi
  fi
  printf '%s\t%s\n' "$line_idx" "$current"
}

# Write `SCRIBE_PROMPT=<value>` to the line at $1; append a new line if $1 empty.
_vocab_write_line() {
  local line_idx=$1 new_line=$2
  if [[ -n "$line_idx" ]]; then
    local tmp
    tmp=$(mktemp)
    NEW_LINE="$new_line" awk -v idx="$line_idx" \
      'NR==idx {print ENVIRON["NEW_LINE"]; next} {print}' \
      "$ENV_FILE" > "$tmp"
    mv "$tmp" "$ENV_FILE"
  else
    printf '\n%s\n' "$new_line" >> "$ENV_FILE"
  fi
}

# Split "a, b, c" into an array; trims whitespace, drops empties.
_vocab_split_into() {
  local -n arr=$1
  local raw=$2 p trimmed
  arr=()
  [[ -z "$raw" ]] && return 0
  local -a parts
  IFS=',' read -ra parts <<< "$raw"
  for p in "${parts[@]}"; do
    trimmed="${p#"${p%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -n "$trimmed" ]] && arr+=("$trimmed")
  done
}

# Join "${arr[@]}" with ", "; result in $1.
_vocab_join_into() {
  local -n out=$1
  shift
  out=""
  local i
  for i in "$@"; do
    if [[ -z "$out" ]]; then
      out="$i"
    else
      out="$out, $i"
    fi
  done
}

_vocab_restart_if_active() {
  systemctl --user is-active --quiet "$SERVICE" 2>/dev/null || return 0
  echo
  printf "  %s→ restarting Scribe to apply the change…%s\n" "$D" "$N"
  if systemctl --user restart "$SERVICE"; then
    printf "  %s✓%s Scribe restarted\n" "$G" "$N"
  else
    printf "  %s✗%s Couldn't restart Scribe — see: journalctl --user -u scribe -n 50\n" "$R" "$N" >&2
  fi
}

cmd_list() {
  local line_idx current parsed
  parsed=$(_vocab_read)
  line_idx="${parsed%%	*}"
  current="${parsed#*	}"

  local -a terms
  _vocab_split_into terms "$current"

  if (( ${#terms[@]} == 0 )); then
    printf "  %s○%s Your custom vocabulary is empty.\n" "$D" "$N"
    printf "  %sAdd words with:%s scribe add <word>...\n" "$D" "$N"
    return 0
  fi

  printf "  %s%sCustom vocabulary (%d):%s\n" "$B" "$C" "${#terms[@]}" "$N"
  local t
  for t in "${terms[@]}"; do
    printf "    %s•%s %s\n" "$D" "$N" "$t"
  done
}

cmd_add() {
  if [[ $# -eq 0 ]]; then
    echo "scribe add: tell me which words to add" >&2
    echo "usage: scribe add <word>... — wrap multi-word phrases in quotes" >&2
    exit 2
  fi
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "scribe: .env not found at $ENV_FILE" >&2
    exit 1
  fi

  local line_idx current parsed
  parsed=$(_vocab_read)
  line_idx="${parsed%%	*}"
  current="${parsed#*	}"

  local -a existing=()
  _vocab_split_into existing "$current"

  declare -A seen=()
  local t
  for t in "${existing[@]}"; do
    seen[${t,,}]=1
  done

  # Explicit =() so the array is "set" for set -u, even if never appended to.
  local -a added=()
  local item trimmed
  for item in "$@"; do
    trimmed="${item#"${item%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -z "$trimmed" ]] && continue
    [[ -n "${seen[${trimmed,,}]+x}" ]] && continue
    seen[${trimmed,,}]=1
    added+=("$trimmed")
  done

  if (( ${#added[@]} == 0 )); then
    printf "  %s○%s Nothing to add — those words are already in your vocabulary.\n" "$D" "$N"
    return 0
  fi

  local joined_new new_value
  _vocab_join_into joined_new "${added[@]}"
  if [[ -n "$current" ]]; then
    new_value="$current, $joined_new"
  else
    new_value="$joined_new"
  fi

  _vocab_write_line "$line_idx" "SCRIBE_PROMPT=$new_value"

  printf "  %s✓%s Added: %s%s%s\n\n" "$G" "$N" "$B" "$joined_new" "$N"
  printf "  %sYour vocabulary is now:%s\n" "$D" "$N"
  printf "  %s%s%s\n" "$C" "$new_value" "$N"
  _vocab_restart_if_active
}

cmd_remove() {
  if [[ $# -eq 0 ]]; then
    echo "scribe remove: tell me which words to remove" >&2
    echo "usage: scribe remove <word>... — wrap multi-word phrases in quotes" >&2
    exit 2
  fi
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "scribe: .env not found at $ENV_FILE" >&2
    exit 1
  fi

  local line_idx current parsed
  parsed=$(_vocab_read)
  line_idx="${parsed%%	*}"
  current="${parsed#*	}"

  if [[ -z "$current" ]]; then
    printf "  %s○%s Nothing to remove — your custom vocabulary is empty.\n" "$D" "$N"
    return 0
  fi

  # Map lowercase → original-cased term for "not found" reporting later.
  declare -A targets=()
  local arg trimmed
  for arg in "$@"; do
    trimmed="${arg#"${arg%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -n "$trimmed" ]] && targets[${trimmed,,}]="$trimmed"
  done

  # Explicit =() so the arrays are "set" for set -u, even if never appended to.
  local -a existing=() kept=() removed=()
  _vocab_split_into existing "$current"
  local t
  for t in "${existing[@]}"; do
    if [[ -n "${targets[${t,,}]+x}" ]]; then
      removed+=("$t")
      unset 'targets[${t,,}]'
    else
      kept+=("$t")
    fi
  done

  # Collect the original-cased "not found" terms in input order for nicer output.
  local -a notfound=()
  for arg in "$@"; do
    trimmed="${arg#"${arg%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -z "$trimmed" ]] && continue
    [[ -n "${targets[${trimmed,,}]+x}" ]] && notfound+=("${targets[${trimmed,,}]}")
  done

  if (( ${#removed[@]} == 0 )); then
    local notfound_joined
    _vocab_join_into notfound_joined "${notfound[@]}"
    printf "  %s⚠%s  Not in your vocabulary: %s%s%s\n\n" "$Y" "$N" "$B" "$notfound_joined" "$N"
    printf "  %sNo changes. Current vocabulary (%d):%s\n" "$D" "${#existing[@]}" "$N"
    for t in "${existing[@]}"; do
      printf "    %s•%s %s\n" "$D" "$N" "$t"
    done
    return 0
  fi

  local new_value
  _vocab_join_into new_value "${kept[@]}"
  _vocab_write_line "$line_idx" "SCRIBE_PROMPT=$new_value"

  local removed_joined
  _vocab_join_into removed_joined "${removed[@]}"
  printf "  %s✓%s Removed: %s%s%s\n" "$G" "$N" "$B" "$removed_joined" "$N"

  if (( ${#notfound[@]} > 0 )); then
    local notfound_joined
    _vocab_join_into notfound_joined "${notfound[@]}"
    printf "  %s⚠%s  Not in your vocabulary: %s\n" "$Y" "$N" "$notfound_joined"
  fi

  echo
  printf "  %sYour vocabulary is now:%s\n" "$D" "$N"
  if [[ -n "$new_value" ]]; then
    printf "  %s%s%s\n" "$C" "$new_value" "$N"
  else
    printf "  %s(empty)%s\n" "$D" "$N"
  fi
  _vocab_restart_if_active
}

cmd_update() {
  local installer="$SCRIBE_DIR/install.sh"
  if [[ ! -f "$installer" ]]; then
    printf "  %s✗%s Can't find the installer at %s — the Scribe folder looks broken.\n" \
      "$R" "$N" "$installer" >&2
    exit 1
  fi

  # Pull latest code if this is a git checkout. Manual installs skip this.
  if [[ -d "$SCRIBE_DIR/.git" ]]; then
    printf "  %s→ checking for updates…%s\n" "$D" "$N"
    if ! git -C "$SCRIBE_DIR" pull --ff-only; then
      echo >&2
      printf "  %s✗%s Couldn't pull updates. If you've edited files in %s,\n" \
        "$R" "$N" "$SCRIBE_DIR" >&2
      printf "      commit/stash them — or remove the folder and reinstall.\n" >&2
      exit 1
    fi
  else
    printf "  %s○%s Skipping git pull — %s isn't a git checkout.\n" "$D" "$N" "$SCRIBE_DIR"
  fi

  # Hand off to install.sh — single source of truth for install behavior.
  # It's idempotent: existing .env/venv/unit file get refreshed, no prompts.
  exec bash "$installer"
}

cmd_uninstall() {
  local force=0
  local arg
  for arg in "$@"; do
    case "$arg" in
      -y|--yes) force=1 ;;
      *)
        echo "scribe uninstall: unknown arg: $arg" >&2
        echo "usage: scribe uninstall [-y]" >&2
        exit 2
        ;;
    esac
  done

  local unit_file="$HOME/.config/systemd/user/$SERVICE"
  local self_path="$HOME/.local/bin/scribe"
  # Only delete the Scribe folder if it lives at the canonical XDG location.
  # If the user cloned it themselves to e.g. ~/code/scribe, leaving it alone
  # is the right thing — that's their working directory, not ours to remove.
  local xdg_dir="${XDG_DATA_HOME:-$HOME/.local/share}/scribe"
  local folder_managed=0
  [[ "$SCRIBE_DIR" == "$xdg_dir" ]] && folder_managed=1

  local items=()
  [[ -f "$unit_file" ]] && items+=("auto-start setup:  $unit_file")
  [[ -f "$self_path" ]] && items+=("scribe command:    $self_path")
  (( folder_managed )) && [[ -d "$SCRIBE_DIR" ]] && \
    items+=("Scribe folder:     $SCRIBE_DIR")

  if (( ${#items[@]} == 0 )); then
    echo "Nothing to uninstall — Scribe doesn't seem to be set up on this system."
    return 0
  fi

  printf "%sWill remove:%s\n" "$B" "$N"
  local i
  for i in "${items[@]}"; do
    printf "  %s-%s %s\n" "$D" "$N" "$i"
  done
  echo
  printf "%sWill NOT touch:%s\n" "$B" "$N"
  if (( ! folder_managed )); then
    printf "  %s-%s the Scribe folder at %s (delete it yourself if you want it gone)\n" "$D" "$N" "$SCRIBE_DIR"
  fi
  [[ -f "$ENV_FILE" ]] && \
    printf "  %s-%s your config at %s (so reinstall keeps your API key)\n" "$D" "$N" "$ENV_FILE"
  printf "  %s-%s the ydotool and wl-clipboard packages\n" "$D" "$N"
  printf "  %s-%s your membership in the 'input' group\n" "$D" "$N"
  echo

  if (( ! force )); then
    local choice
    choice=$(select_yes_no "Continue?" 1)
    if (( choice != 0 )); then
      printf "  %sCancelled.%s\n" "$D" "$N"
      return 0
    fi
  fi

  if [[ -f "$unit_file" ]]; then
    if systemctl --user is-active --quiet "$SERVICE" 2>/dev/null; then
      printf "  %s→ stopping Scribe…%s\n" "$D" "$N"
      systemctl --user stop "$SERVICE" || true
    fi
    if systemctl --user is-enabled --quiet "$SERVICE" 2>/dev/null; then
      printf "  %s→ turning off auto-start…%s\n" "$D" "$N"
      systemctl --user disable "$SERVICE" >/dev/null 2>&1 || true
    fi
    rm -f "$unit_file"
    systemctl --user daemon-reload || true
    printf "  %s✓%s Removed %s\n" "$G" "$N" "$unit_file"
  fi

  # Remove the wrapper before the folder — Linux keeps the inode alive while
  # we're running, so overwriting/deleting the file we're executing is safe.
  if [[ -f "$self_path" ]]; then
    rm -f "$self_path"
    printf "  %s✓%s Removed %s\n" "$G" "$N" "$self_path"
  fi

  if (( folder_managed )) && [[ -d "$SCRIBE_DIR" ]]; then
    rm -rf "$SCRIBE_DIR"
    printf "  %s✓%s Removed %s\n" "$G" "$N" "$SCRIBE_DIR"
  fi

  echo
  printf "  %s%sScribe uninstalled.%s\n" "$B" "$G" "$N"
  if (( ! folder_managed )); then
    printf "  %sIf you want to delete the Scribe folder too:%s\n" "$D" "$N"
    printf "    %srm -rf %s%s\n" "$D" "$SCRIBE_DIR" "$N"
    printf "  %sYour API key in %s is also kept — delete it manually if you want it gone.%s\n" \
      "$D" "$ENV_FILE" "$N"
  fi
}

case "${1:-}" in
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  restart)   cmd_restart ;;
  status)    cmd_status ;;
  test)      cmd_test ;;
  list)      cmd_list ;;
  update)    cmd_update ;;
  add)
    shift
    cmd_add "$@"
    ;;
  remove|rm)
    shift
    cmd_remove "$@"
    ;;
  uninstall)
    shift
    cmd_uninstall "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "scribe: unknown command: $1" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
