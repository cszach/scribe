#!/usr/bin/env bash
# scribe — control the Scribe dictation daemon.
#
# Installed by install.sh; __SCRIBE_DIR__ is replaced at install time with the
# absolute path of the repo so this script can find .env.

set -euo pipefail

SCRIBE_DIR="__SCRIBE_DIR__"
ENV_FILE="$SCRIBE_DIR/.env"
SERVICE="scribe.service"

if [[ -t 1 ]]; then
  R=$'\033[31m'; G=$'\033[32m'; Y=$'\033[33m'; C=$'\033[36m'; M=$'\033[35m'
  B=$'\033[1m'; D=$'\033[2m'; N=$'\033[0m'
else
  R=; G=; Y=; C=; M=; B=; D=; N=
fi

print_logo() {
  [[ -t 1 ]] || return 0
  printf '%s' "$M"
  cat <<'BANNER'

   ███████╗ ██████╗██████╗ ██╗██████╗ ███████╗
   ██╔════╝██╔════╝██╔══██╗██║██╔══██╗██╔════╝
   ███████╗██║     ██████╔╝██║██████╔╝█████╗
   ╚════██║██║     ██╔══██╗██║██╔══██╗██╔══╝
   ███████║╚██████╗██║  ██║██║██████╔╝███████╗
   ╚══════╝ ╚═════╝╚═╝  ╚═╝╚═╝╚═════╝ ╚══════╝
BANNER
  printf '%s' "$N"
  printf "   %sPush-to-talk dictation for Linux, powered by Groq Whisper%s\n\n" "$D" "$N"
}

# Arrow-key Yes/No selector. Echoes 0 (Yes) or 1 (No).
# Falls back to a Y/n prompt if there's no tty.
select_yes_no() {
  local prompt=$1
  local selected=${2:-0}
  local options=("Yes" "No")
  local count=2
  local key rest old_stty i ans

  if [[ ! -t 0 ]] || [[ ! -e /dev/tty ]]; then
    local hint="Y/n"
    (( selected == 1 )) && hint="y/N"
    printf "  %s%s%s %s[%s]%s: " "$C" "$prompt" "$N" "$D" "$hint" "$N" >&2
    read -r ans
    if [[ -z $ans ]]; then
      echo "$selected"
    elif [[ $ans =~ ^[Yy] ]]; then
      echo 0
    else
      echo 1
    fi
    return
  fi

  old_stty=$(stty -g </dev/tty)
  stty -icanon -echo min 1 time 0 </dev/tty
  printf '\033[?25l' >/dev/tty
  trap '
    stty "$old_stty" </dev/tty 2>/dev/null
    printf "\033[?25h" >/dev/tty 2>/dev/null
    exit 130
  ' INT

  draw_yn() {
    {
      printf "  %s%s%s\n" "$C" "$prompt" "$N"
      printf "    "
      for i in "${!options[@]}"; do
        if (( i == selected )); then
          printf "%s❯%s %s%s%s    " "$M" "$N" "$B$C" "${options[i]}" "$N"
        else
          printf "  %s%s%s    " "$D" "${options[i]}" "$N"
        fi
      done
      printf "\n"
      printf "  %s←→ navigate, enter to select%s\n" "$D" "$N"
    } >/dev/tty
  }

  draw_yn
  while true; do
    IFS= read -rsn1 key </dev/tty
    if [[ $key == $'\x1b' ]]; then
      IFS= read -rsn2 -t 0.05 rest </dev/tty || rest=""
      case $rest in
        '[C') (( selected = (selected + 1) % count ))
              printf "\033[3A" >/dev/tty; draw_yn ;;
        '[D') (( selected = (selected - 1 + count) % count ))
              printf "\033[3A" >/dev/tty; draw_yn ;;
      esac
    elif [[ -z $key ]]; then
      {
        printf "\033[3A"
        printf '\033[J'
        printf "  %s%s%s %s%s%s\n" "$C" "$prompt" "$N" "$B" "${options[selected]}" "$N"
      } >/dev/tty
      stty "$old_stty" </dev/tty
      printf "\033[?25h" >/dev/tty
      trap - INT
      echo "$selected"
      return
    fi
  done
}

# Print a one-line summary of the current service state. Best-effort; if
# `systemctl status` parsing fails (locale, systemd version), we degrade
# gracefully to just the state word.
status_line() {
  local state pid uptime
  state=$(systemctl --user is-active "$SERVICE" 2>/dev/null || true)
  pid=$(systemctl --user show -p MainPID --value "$SERVICE" 2>/dev/null || true)
  uptime=$(systemctl --user status "$SERVICE" --no-pager 2>/dev/null \
           | sed -nE 's/.*Active: active \([^)]+\) since [^;]+; (.+) ago.*/\1/p' \
           | head -1 || true)

  case "$state" in
    active)
      if [[ -n "$uptime" && -n "$pid" && "$pid" != "0" ]]; then
        printf "  %s●%s scribe is %s%srunning%s (pid %s, up %s)\n" \
          "$G" "$N" "$G" "$B" "$N" "$pid" "$uptime"
      elif [[ -n "$pid" && "$pid" != "0" ]]; then
        printf "  %s●%s scribe is %s%srunning%s (pid %s)\n" \
          "$G" "$N" "$G" "$B" "$N" "$pid"
      else
        printf "  %s●%s scribe is %s%srunning%s\n" "$G" "$N" "$G" "$B" "$N"
      fi
      ;;
    inactive)
      printf "  %s○%s scribe is %sstopped%s\n" "$D" "$N" "$D" "$N"
      ;;
    failed)
      printf "  %s✗%s scribe %sfailed%s — see: journalctl --user -u scribe -n 50\n" \
        "$R" "$N" "$R$B" "$N"
      ;;
    activating)
      printf "  %s●%s scribe is %sstarting…%s\n" "$Y" "$N" "$Y" "$N"
      ;;
    deactivating)
      printf "  %s●%s scribe is %sstopping…%s\n" "$Y" "$N" "$Y" "$N"
      ;;
    "")
      printf "  %s✗%s %s not found — run install.sh to enable autostart\n" \
        "$R" "$N" "$SERVICE"
      ;;
    *)
      printf "  %s●%s scribe: %s\n" "$Y" "$N" "$state"
      ;;
  esac
}

cmd_start() {
  local state
  state=$(systemctl --user is-active "$SERVICE" 2>/dev/null || true)
  if [[ "$state" == "active" ]]; then
    printf "  %s●%s already running.\n" "$Y" "$N"
    status_line
    return 0
  fi
  printf "  %s→ starting scribe…%s\n" "$D" "$N"
  if ! systemctl --user start "$SERVICE"; then
    printf "  %s✗%s failed to start — see: journalctl --user -u scribe -n 50\n" "$R" "$N"
    exit 1
  fi
  status_line
}

cmd_stop() {
  local state
  state=$(systemctl --user is-active "$SERVICE" 2>/dev/null || true)
  if [[ "$state" != "active" && "$state" != "activating" ]]; then
    printf "  %s○%s already stopped.\n" "$D" "$N"
    return 0
  fi
  printf "  %s→ stopping scribe…%s\n" "$D" "$N"
  if ! systemctl --user stop "$SERVICE"; then
    printf "  %s✗%s failed to stop.\n" "$R" "$N"
    exit 1
  fi
  printf "  %s○%s scribe %sstopped%s.\n" "$D" "$N" "$D" "$N"
}

cmd_restart() {
  printf "  %s→ restarting scribe…%s\n" "$D" "$N"
  if ! systemctl --user restart "$SERVICE"; then
    printf "  %s✗%s failed to restart — see: journalctl --user -u scribe -n 50\n" "$R" "$N"
    exit 1
  fi
  status_line
}

cmd_test() {
  local py="$SCRIBE_DIR/.venv/bin/python"
  local helper="$SCRIBE_DIR/scribe_test.py"
  if [[ ! -x "$py" ]]; then
    printf "  %s✗%s venv not found at %s/.venv — run install.sh first\n" \
      "$R" "$N" "$SCRIBE_DIR" >&2
    exit 1
  fi
  if [[ ! -f "$helper" ]]; then
    printf "  %s✗%s %s missing — repo is incomplete\n" "$R" "$N" "$helper" >&2
    exit 1
  fi
  exec "$py" "$helper"
}

# Read a key from .env, ignoring commented lines. Echoes the value, or empty.
env_get() {
  local key=$1
  [[ -f "$ENV_FILE" ]] || return 0
  grep -E "^[[:space:]]*$key=" "$ENV_FILE" 2>/dev/null \
    | tail -1 | cut -d= -f2- || true
}

cmd_status() {
  status_line

  local enabled enabled_color enabled_text
  enabled=$(systemctl --user is-enabled "$SERVICE" 2>/dev/null || true)
  case "$enabled" in
    enabled)         enabled_color="$G"; enabled_text="enabled" ;;
    disabled|static) enabled_color="$Y"; enabled_text="$enabled" ;;
    "")              enabled_color="$D"; enabled_text="unknown" ;;
    *)               enabled_color="$D"; enabled_text="$enabled" ;;
  esac
  printf "  %sAutostart:%s   %s%s%s\n" "$D" "$N" "$enabled_color" "$enabled_text" "$N"

  local hotkey paste
  hotkey=$(env_get SCRIBE_HOTKEY)
  if [[ -z "$hotkey" ]]; then
    printf "  %sHotkey:%s      KEY_RIGHTCTRL %s(default)%s\n" "$D" "$N" "$D" "$N"
  else
    printf "  %sHotkey:%s      %s\n" "$D" "$N" "$hotkey"
  fi

  paste=$(env_get SCRIBE_PASTE_MODE)
  if [[ -z "$paste" ]]; then
    printf "  %sPaste mode:%s  shortcut %s(default)%s\n" "$D" "$N" "$D" "$N"
  else
    printf "  %sPaste mode:%s  %s\n" "$D" "$N" "$paste"
  fi

  echo
  printf "  %sRecent logs:%s\n" "$D" "$N"
  local logs line
  logs=$(journalctl --user -u "$SERVICE" --no-pager -n 6 -o cat 2>/dev/null || true)
  if [[ -n "$logs" ]]; then
    while IFS= read -r line; do
      printf "    %s│%s %s\n" "$D" "$N" "$line"
    done <<< "$logs"
  else
    printf "    %s(no logs yet)%s\n" "$D" "$N"
  fi
}

usage() {
  print_logo
  printf "  %sUsage:%s %sscribe%s <command> [args]\n\n" "$B" "$N" "$C$B" "$N"
  printf "  %sCommands:%s\n" "$B" "$N"
  printf "      %sstart%s              Start the scribe systemd user service.\n" "$C$B" "$N"
  printf "      %sstop%s               Stop the scribe systemd user service.\n" "$C$B" "$N"
  printf "      %srestart%s            Restart the scribe systemd user service.\n" "$C$B" "$N"
  printf "      %sstatus%s             Show scribe service status.\n" "$C$B" "$N"
  printf "      %stest%s               Record once and transcribe to verify the pipeline.\n" "$C$B" "$N"
  printf "      %slist%s               List vocabulary terms in SCRIBE_PROMPT.\n" "$C$B" "$N"
  printf "      %sadd%s <term>…        Add terms to SCRIBE_PROMPT (quote multi-word).\n" "$C$B" "$N"
  printf "      %sremove%s <term>…     Remove matching terms (case-insensitive).\n" "$C$B" "$N"
  printf "      %sreinstall%s          Refresh CLI, sync Python deps, restart daemon if running.\n" "$C$B" "$N"
  printf "      %suninstall%s [-y]     Remove the systemd unit and the CLI wrapper.\n\n" "$C$B" "$N"
  printf "  %s.env:%s %s\n\n" "$D" "$N" "$ENV_FILE"
}

# Locate SCRIBE_PROMPT and echo "<line_idx>\t<current_value>". Last match wins
# so a real setting below a commented placeholder takes precedence. Either or
# both fields may be empty.
_vocab_read() {
  local line_idx="" current=""
  if [[ -f "$ENV_FILE" ]]; then
    line_idx=$(grep -nE '^[[:space:]]*#?[[:space:]]*SCRIBE_PROMPT=' "$ENV_FILE" \
               | tail -1 | cut -d: -f1 || true)
    if [[ -n "$line_idx" ]]; then
      current=$(sed -n "${line_idx}p" "$ENV_FILE" \
                | sed -E 's/^[[:space:]]*#?[[:space:]]*SCRIBE_PROMPT=//')
      current="${current%\"}"; current="${current#\"}"
    fi
  fi
  printf '%s\t%s\n' "$line_idx" "$current"
}

# Write `SCRIBE_PROMPT=<value>` to the line at $1; append a new line if $1 empty.
_vocab_write_line() {
  local line_idx=$1 new_line=$2
  if [[ -n "$line_idx" ]]; then
    local tmp
    tmp=$(mktemp)
    NEW_LINE="$new_line" awk -v idx="$line_idx" \
      'NR==idx {print ENVIRON["NEW_LINE"]; next} {print}' \
      "$ENV_FILE" > "$tmp"
    mv "$tmp" "$ENV_FILE"
  else
    printf '\n%s\n' "$new_line" >> "$ENV_FILE"
  fi
}

# Split "a, b, c" into an array; trims whitespace, drops empties.
_vocab_split_into() {
  local -n arr=$1
  local raw=$2 p trimmed
  arr=()
  [[ -z "$raw" ]] && return 0
  local -a parts
  IFS=',' read -ra parts <<< "$raw"
  for p in "${parts[@]}"; do
    trimmed="${p#"${p%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -n "$trimmed" ]] && arr+=("$trimmed")
  done
}

# Join "${arr[@]}" with ", "; result in $1.
_vocab_join_into() {
  local -n out=$1
  shift
  out=""
  local i
  for i in "$@"; do
    if [[ -z "$out" ]]; then
      out="$i"
    else
      out="$out, $i"
    fi
  done
}

_vocab_restart_if_active() {
  systemctl --user is-active --quiet "$SERVICE" 2>/dev/null || return 0
  echo
  printf "  %s→ restarting scribe to apply…%s\n" "$D" "$N"
  if systemctl --user restart "$SERVICE"; then
    printf "  %s✓%s Service restarted\n" "$G" "$N"
  else
    printf "  %s✗%s restart failed — see: journalctl --user -u scribe -n 50\n" "$R" "$N" >&2
  fi
}

cmd_list() {
  local line_idx current parsed
  parsed=$(_vocab_read)
  line_idx="${parsed%%	*}"
  current="${parsed#*	}"

  local -a terms
  _vocab_split_into terms "$current"

  if (( ${#terms[@]} == 0 )); then
    printf "  %s○%s No vocabulary terms set.\n" "$D" "$N"
    printf "  %sAdd with:%s scribe add <term>...\n" "$D" "$N"
    return 0
  fi

  printf "  %s%sVocabulary terms (%d):%s\n" "$B" "$C" "${#terms[@]}" "$N"
  local t
  for t in "${terms[@]}"; do
    printf "    %s•%s %s\n" "$D" "$N" "$t"
  done
}

cmd_add() {
  if [[ $# -eq 0 ]]; then
    echo "scribe add: nothing to add" >&2
    echo "usage: scribe add <term>... — wrap multi-word terms in quotes" >&2
    exit 2
  fi
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "scribe: .env not found at $ENV_FILE" >&2
    exit 1
  fi

  local line_idx current parsed
  parsed=$(_vocab_read)
  line_idx="${parsed%%	*}"
  current="${parsed#*	}"

  local -a existing=()
  _vocab_split_into existing "$current"

  declare -A seen=()
  local t
  for t in "${existing[@]}"; do
    seen[${t,,}]=1
  done

  # Explicit =() so the array is "set" for set -u, even if never appended to.
  local -a added=()
  local item trimmed
  for item in "$@"; do
    trimmed="${item#"${item%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -z "$trimmed" ]] && continue
    [[ -n "${seen[${trimmed,,}]+x}" ]] && continue
    seen[${trimmed,,}]=1
    added+=("$trimmed")
  done

  if (( ${#added[@]} == 0 )); then
    printf "  %s○%s Nothing to add — all terms already in SCRIBE_PROMPT.\n" "$D" "$N"
    return 0
  fi

  local joined_new new_value
  _vocab_join_into joined_new "${added[@]}"
  if [[ -n "$current" ]]; then
    new_value="$current, $joined_new"
  else
    new_value="$joined_new"
  fi

  _vocab_write_line "$line_idx" "SCRIBE_PROMPT=$new_value"

  printf "  %s✓%s Added: %s%s%s\n\n" "$G" "$N" "$B" "$joined_new" "$N"
  printf "  %sSCRIBE_PROMPT now reads:%s\n" "$D" "$N"
  printf "  %s%s%s\n" "$C" "$new_value" "$N"
  _vocab_restart_if_active
}

cmd_remove() {
  if [[ $# -eq 0 ]]; then
    echo "scribe remove: nothing to remove" >&2
    echo "usage: scribe remove <term>... — wrap multi-word terms in quotes" >&2
    exit 2
  fi
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "scribe: .env not found at $ENV_FILE" >&2
    exit 1
  fi

  local line_idx current parsed
  parsed=$(_vocab_read)
  line_idx="${parsed%%	*}"
  current="${parsed#*	}"

  if [[ -z "$current" ]]; then
    printf "  %s○%s No vocabulary to remove — SCRIBE_PROMPT is empty.\n" "$D" "$N"
    return 0
  fi

  # Map lowercase → original-cased term for "not found" reporting later.
  declare -A targets=()
  local arg trimmed
  for arg in "$@"; do
    trimmed="${arg#"${arg%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -n "$trimmed" ]] && targets[${trimmed,,}]="$trimmed"
  done

  # Explicit =() so the arrays are "set" for set -u, even if never appended to.
  local -a existing=() kept=() removed=()
  _vocab_split_into existing "$current"
  local t
  for t in "${existing[@]}"; do
    if [[ -n "${targets[${t,,}]+x}" ]]; then
      removed+=("$t")
      unset 'targets[${t,,}]'
    else
      kept+=("$t")
    fi
  done

  # Collect the original-cased "not found" terms in input order for nicer output.
  local -a notfound=()
  for arg in "$@"; do
    trimmed="${arg#"${arg%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -z "$trimmed" ]] && continue
    [[ -n "${targets[${trimmed,,}]+x}" ]] && notfound+=("${targets[${trimmed,,}]}")
  done

  if (( ${#removed[@]} == 0 )); then
    local notfound_joined
    _vocab_join_into notfound_joined "${notfound[@]}"
    printf "  %s⚠%s  Not found: %s%s%s\n\n" "$Y" "$N" "$B" "$notfound_joined" "$N"
    printf "  %sVocabulary unchanged. Current terms (%d):%s\n" "$D" "${#existing[@]}" "$N"
    for t in "${existing[@]}"; do
      printf "    %s•%s %s\n" "$D" "$N" "$t"
    done
    return 0
  fi

  local new_value
  _vocab_join_into new_value "${kept[@]}"
  _vocab_write_line "$line_idx" "SCRIBE_PROMPT=$new_value"

  local removed_joined
  _vocab_join_into removed_joined "${removed[@]}"
  printf "  %s✓%s Removed: %s%s%s\n" "$G" "$N" "$B" "$removed_joined" "$N"

  if (( ${#notfound[@]} > 0 )); then
    local notfound_joined
    _vocab_join_into notfound_joined "${notfound[@]}"
    printf "  %s⚠%s  Not found: %s\n" "$Y" "$N" "$notfound_joined"
  fi

  echo
  printf "  %sSCRIBE_PROMPT now reads:%s\n" "$D" "$N"
  if [[ -n "$new_value" ]]; then
    printf "  %s%s%s\n" "$C" "$new_value" "$N"
  else
    printf "  %s(empty)%s\n" "$D" "$N"
  fi
  _vocab_restart_if_active
}

cmd_reinstall() {
  local src="$SCRIBE_DIR/bin/scribe"
  local bin_dir="$HOME/.local/bin"
  local dest="$bin_dir/scribe"

  if [[ ! -f "$src" ]]; then
    printf "  %s✗%s source CLI missing at %s — repo is incomplete\n" \
      "$R" "$N" "$src" >&2
    exit 1
  fi

  # 1. Refresh the CLI wrapper.
  # Build the placeholder at runtime so install.sh's own templating pass
  # doesn't replace this literal inside the installed copy — otherwise
  # subsequent reinstalls would have nothing to substitute. Linux keeps this
  # file's inode alive while we're running, so overwriting it is safe.
  mkdir -p "$bin_dir"
  local placeholder
  placeholder=$(printf '__%s__' 'SCRIBE_DIR')
  local template
  template=$(<"$src")
  printf '%s\n' "${template//$placeholder/$SCRIBE_DIR}" > "$dest"
  chmod +x "$dest"
  printf "  %s✓%s CLI wrapper updated %s(%s)%s\n" "$G" "$N" "$D" "$dest" "$N"

  # 2. Sync Python dependencies. The service points at $SCRIBE_DIR/scribe.py
  # directly, so the daemon code itself is always current — we just need to
  # make sure its dependencies match requirements.txt.
  local venv_pip="$SCRIBE_DIR/.venv/bin/pip"
  local req="$SCRIBE_DIR/requirements.txt"
  if [[ ! -x "$venv_pip" ]]; then
    printf "  %s⚠%s  No venv at %s/.venv — skipping dependency sync. Run install.sh first.\n" \
      "$Y" "$N" "$SCRIBE_DIR"
  elif [[ ! -f "$req" ]]; then
    printf "  %s⚠%s  No requirements.txt — skipping dependency sync.\n" "$Y" "$N"
  else
    printf "  %s→ syncing Python dependencies…%s\n" "$D" "$N"
    local log
    log=$(mktemp)
    if "$venv_pip" install -q -r "$req" >"$log" 2>&1; then
      printf "  %s✓%s Dependencies in sync with requirements.txt\n" "$G" "$N"
    else
      printf "  %s✗%s pip install failed:\n" "$R" "$N" >&2
      cat "$log" >&2
      rm -f "$log"
      exit 1
    fi
    rm -f "$log"
  fi

  # 3. Restart the daemon if it's running so scribe.py changes take effect.
  local state
  state=$(systemctl --user is-active "$SERVICE" 2>/dev/null || true)
  if [[ "$state" == "active" ]]; then
    printf "  %s→ restarting scribe…%s\n" "$D" "$N"
    if systemctl --user restart "$SERVICE"; then
      printf "  %s✓%s Service restarted\n" "$G" "$N"
    else
      printf "  %s✗%s restart failed — see: journalctl --user -u scribe -n 50\n" "$R" "$N" >&2
      exit 1
    fi
  elif systemctl --user is-enabled --quiet "$SERVICE" 2>/dev/null; then
    printf "  %s○%s Service installed but not running — start with: scribe start\n" "$D" "$N"
  else
    printf "  %s○%s No systemd service (skip restart). Run install.sh to set up autostart.\n" "$D" "$N"
  fi

  echo
  printf "  %s%sReinstall complete.%s\n" "$B" "$G" "$N"
}

cmd_uninstall() {
  local force=0
  local arg
  for arg in "$@"; do
    case "$arg" in
      -y|--yes) force=1 ;;
      *)
        echo "scribe uninstall: unknown arg: $arg" >&2
        echo "usage: scribe uninstall [-y]" >&2
        exit 2
        ;;
    esac
  done

  local unit_file="$HOME/.config/systemd/user/$SERVICE"
  local self_path="$HOME/.local/bin/scribe"
  local items=()

  [[ -f "$unit_file" ]] && items+=("systemd unit:  $unit_file")
  [[ -f "$self_path" ]] && items+=("CLI wrapper:   $self_path")

  if (( ${#items[@]} == 0 )); then
    echo "Nothing to uninstall — no unit file or CLI wrapper found."
    printf "Repo at %s is untouched (delete with: rm -rf %s).\n" \
      "$SCRIBE_DIR" "$SCRIBE_DIR"
    return 0
  fi

  printf "%sWill remove:%s\n" "$B" "$N"
  local i
  for i in "${items[@]}"; do
    printf "  %s-%s %s\n" "$D" "$N" "$i"
  done
  echo
  printf "%sWill NOT touch:%s\n" "$B" "$N"
  printf "  %s-%s repo at %s (with .venv, .env, scribe.py)\n" "$D" "$N" "$SCRIBE_DIR"
  printf "  %s-%s system packages (ydotool, wl-clipboard)\n" "$D" "$N"
  printf "  %s-%s your membership in the 'input' group\n" "$D" "$N"
  echo

  if (( ! force )); then
    local choice
    choice=$(select_yes_no "Continue?" 1)
    if (( choice != 0 )); then
      printf "  %sCancelled.%s\n" "$D" "$N"
      return 0
    fi
  fi

  if [[ -f "$unit_file" ]]; then
    if systemctl --user is-active --quiet "$SERVICE" 2>/dev/null; then
      printf "  %s→ stopping scribe…%s\n" "$D" "$N"
      systemctl --user stop "$SERVICE" || true
    fi
    if systemctl --user is-enabled --quiet "$SERVICE" 2>/dev/null; then
      printf "  %s→ disabling autostart…%s\n" "$D" "$N"
      systemctl --user disable "$SERVICE" >/dev/null 2>&1 || true
    fi
    rm -f "$unit_file"
    systemctl --user daemon-reload || true
    printf "  %s✓%s removed %s\n" "$G" "$N" "$unit_file"
  fi

  # Remove the wrapper last; Linux keeps the inode alive while we're running.
  if [[ -f "$self_path" ]]; then
    rm -f "$self_path"
    printf "  %s✓%s removed %s\n" "$G" "$N" "$self_path"
  fi

  echo
  printf "  %s%sScribe uninstalled.%s\n" "$B" "$G" "$N"
  printf "  %sTo finish, delete the repo (contains .env with your GROQ_API_KEY):%s\n" "$D" "$N"
  printf "    %scd && rm -rf %s%s\n" "$D" "$SCRIBE_DIR" "$N"
}

case "${1:-}" in
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  restart)   cmd_restart ;;
  status)    cmd_status ;;
  test)      cmd_test ;;
  list)      cmd_list ;;
  reinstall) cmd_reinstall ;;
  add)
    shift
    cmd_add "$@"
    ;;
  remove|rm)
    shift
    cmd_remove "$@"
    ;;
  uninstall)
    shift
    cmd_uninstall "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "scribe: unknown command: $1" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
